<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal, .includes-item').forEach(el => observer.observe(el));
  document.querySelectorAll('.includes-item').forEach((el, i) => { el.style.transitionDelay = `${i * 0.12}s`; });
</script>
