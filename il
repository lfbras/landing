<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brás por LF — Lista de Fornecedores</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream: #F0EDE6; --warm-white: #FAF8F4;
    --gold: #B8A47A; --gold-light: #D4C49A; --gold-dark: #8C7A58;
    --text: #2C2520; --text-mid: #6B5F52; --text-light: #A8998A;
  }
  html { scroll-behavior: smooth; }
  body { background: var(--cream); color: var(--text); font-family: 'Jost', sans-serif; font-weight: 300; overflow-x: hidden; }
  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 1000; opacity: 0.5;
  }
  .hero {
    min-height: 100vh; display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 60px 24px 100px;
    position: relative; text-align: center; background: var(--warm-white); overflow: hidden;
  }
  .hero::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold-light), transparent); }
  .hero-circle { display: none; }
  
  
  @keyframes breathe { 0%,100% { transform: translate(-50%,-50%) scale(1); opacity: 1; } 50% { transform: translate(-50%,-50%) scale(1.03); opacity: 0.7; } }
  .hero-logo { width: 240px; margin-bottom: 12px; margin-top: -40px; animation: fadeUp 1s ease both; object-fit: contain; }
  .hero-eyebrow { font-size: 11px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; animation: fadeUp 1s ease 0.15s both; }
  .hero-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(44px, 8vw, 88px); line-height: 1.0; color: var(--text); margin-bottom: 8px; animation: fadeUp 1s ease 0.25s both; }
  .hero-title em { font-style: italic; color: var(--gold-dark); }
  .hero-subtitle { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: clamp(18px, 3vw, 24px); color: var(--text-mid); margin-top: 10px; margin-bottom: 28px; animation: fadeUp 1s ease 0.35s both; line-height: 1.6; }
  .hero-cta { animation: fadeUp 1s ease 0.5s both; }
  .btn-main { display: inline-block; padding: 18px 52px; background: var(--gold-dark); color: var(--warm-white); font-family: 'Jost', sans-serif; font-weight: 400; font-size: 12px; letter-spacing: 0.25em; text-transform: uppercase; text-decoration: none; cursor: pointer; position: relative; transition: background 0.3s; }
  .btn-main::before { content: ''; position: absolute; inset: 2px; border: 1px solid rgba(255,255,255,0.2); pointer-events: none; }
  .btn-main:hover { background: var(--gold); }
  .hero-price-hint { margin-top: 20px; font-size: 13px; color: var(--text-light); animation: fadeUp 1s ease 0.6s both; }
  .hero-price-hint strong { color: var(--gold-dark); font-weight: 500; }
  .scroll-hint { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--text-light); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; animation: fadeIn 2s ease 1.5s both; }
  .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--gold-light), transparent); animation: scrollPulse 2s ease-in-out infinite; }
  @keyframes scrollPulse { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }
  .section { padding: 100px 24px; }
  .section-inner { max-width: 860px; margin: 0 auto; }
  .section-label { font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); margin-bottom: 24px; display: flex; align-items: center; gap: 16px; }
  .section-label::after { content: ''; flex: 1; height: 1px; background: linear-gradient(to right, var(--gold-light), transparent); max-width: 80px; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(32px, 5vw, 54px); line-height: 1.1; color: var(--text); margin-bottom: 32px; }
  .section-title em { font-style: italic; color: var(--gold-dark); }
  .pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2px; margin-top: 48px; background: var(--gold-light); }
  .pain-item { background: var(--warm-white); padding: 36px 28px; transition: transform 0.3s; }
  .pain-item:hover { transform: translateY(-3px); }
  .pain-icon { font-size: 28px; margin-bottom: 16px; display: block; }
  .pain-text { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic; color: var(--text-mid); line-height: 1.5; }
  .inside-section { background: var(--text); padding: 100px 24px; position: relative; overflow: hidden; }
  .inside-section::before { display: none; }
  .inside-section .section-label { color: var(--gold-light); }
  .inside-section .section-label::after { background: linear-gradient(to right, var(--gold), transparent); }
  .inside-section .section-title { color: var(--warm-white); }
  .inside-section .section-title em { color: var(--gold-light); }
  .includes-list { list-style: none; display: flex; flex-direction: column; margin-top: 48px; }
  .includes-item { display: grid; grid-template-columns: 48px 1fr auto; gap: 24px; align-items: center; padding: 28px 0; border-bottom: 1px solid rgba(255,255,255,0.08); opacity: 0; transform: translateX(-20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .includes-item.visible { opacity: 1; transform: translateX(0); }
  .includes-num { font-family: 'Cormorant Garamond', serif; font-size: 13px; color: var(--gold); letter-spacing: 0.1em; }
  .includes-content h3 { font-family: 'Cormorant Garamond', serif; font-weight: 400; font-size: 22px; color: var(--warm-white); margin-bottom: 6px; }
  .includes-content p { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.6; }
  .includes-badge { display: inline-block; padding: 5px 14px; border: 1px solid rgba(184,164,122,0.4); border-radius: 20px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); white-space: nowrap; }
  .about-section { padding: 100px 24px; background: var(--cream); }
  .about-inner { max-width: 860px; margin: 0 auto; display: grid; grid-template-columns: 160px 1fr; gap: 56px; align-items: center; }
  .about-photo-wrap { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .about-photo { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; object-position: top center; border: 2px solid var(--gold-light); }
  .about-name { font-size: 13px; letter-spacing: 0.08em; color: var(--text); font-weight: 400; }
  .about-role { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-top: 2px; }
  .about-text { font-family: 'Cormorant Garamond', serif; font-size: clamp(18px, 2.5vw, 22px); line-height: 1.75; color: var(--text-mid); font-style: italic; }
  .about-text strong { font-style: normal; color: var(--text); font-weight: 500; }
  .testimonials-section { padding: 100px 24px; background: var(--warm-white); }
  .testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; margin-top: 48px; }
  .testi-card { background: var(--cream); padding: 36px 28px; border-bottom: 2px solid var(--gold-light); }
  .testi-quote { font-family: 'Cormorant Garamond', serif; font-size: 60px; line-height: 0.5; color: var(--gold-light); margin-bottom: 16px; }
  .testi-text { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 18px; color: var(--text-mid); line-height: 1.6; margin-bottom: 20px; }
  .testi-author { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); }
  .how-section { padding: 100px 24px; background: var(--cream); }
  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-top: 60px; position: relative; }
  .steps::before { content: ''; position: absolute; top: 24px; left: 0; right: 0; height: 1px; background: linear-gradient(to right, transparent, var(--gold-light), transparent); }
  .step { text-align: center; }
  .step-num { width: 48px; height: 48px; border-radius: 50%; background: var(--warm-white); border: 1px solid var(--gold-light); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--gold-dark); }
  .step h3 { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 400; color: var(--text); margin-bottom: 8px; }
  .step p { font-size: 13px; color: var(--text-light); line-height: 1.6; }
  .cta-section { padding: 120px 24px; background: var(--text); text-align: center; position: relative; overflow: hidden; }
  .cta-section::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 1px; height: 60px; background: linear-gradient(to bottom, var(--gold), transparent); }
  .cta-logo { width: 180px; margin: 0 auto 48px; display: block; object-fit: contain; }
  .cta-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(36px, 6vw, 70px); color: var(--warm-white); line-height: 1.05; margin-bottom: 16px; }
  .cta-title em { font-style: italic; color: var(--gold-light); }
  .cta-desc { font-size: 15px; color: rgba(255,255,255,0.45); margin-bottom: 52px; max-width: 440px; margin-left: auto; margin-right: auto; line-height: 1.7; }
  .price-block { margin-bottom: 40px; }
  .price-from { font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 4px; }
  .price-value { font-family: 'Cormorant Garamond', serif; font-size: clamp(48px, 8vw, 80px); color: var(--warm-white); line-height: 1; }
  .price-value span { font-size: 0.4em; vertical-align: super; color: var(--gold-light); }
  .price-obs { font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 8px; }
  .btn-cta { display: inline-block; padding: 20px 64px; background: var(--gold-dark); color: var(--warm-white); font-family: 'Jost', sans-serif; font-weight: 400; font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: background 0.3s; position: relative; }
  .btn-cta::before { content: ''; position: absolute; inset: 2px; border: 1px solid rgba(255,255,255,0.15); pointer-events: none; }
  .btn-cta:hover { background: var(--gold); }
  .cta-guarantee { margin-top: 24px; font-size: 12px; color: rgba(255,255,255,0.25); }
  footer { padding: 40px 24px; background: #1A1714; text-align: center; }
  footer p { font-size: 11px; color: rgba(255,255,255,0.2); letter-spacing: 0.1em; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  @media (max-width: 640px) { .steps::before { display: none; } .pain-grid { grid-template-columns: 1fr; } .about-inner { grid-template-columns: 1fr; text-align: center; } .includes-item { grid-template-columns: 36px 1fr; } .includes-badge { display: none; } }
</style>
</head>
<body>

<section class="hero">
